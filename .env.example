# ─── Required ───────────────────────────────────────────────────────────────
# Neon Serverless Postgres connection string
# Get from: https://console.neon.tech → Your project → Connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Secret that gates the manual ingestion trigger endpoint (POST /api/ingest)
# Generate with: openssl rand -hex 32
INGEST_SECRET=change_me_to_a_random_secret

# ─── Optional ────────────────────────────────────────────────────────────────
# GitHub personal access token — increases API rate limit from 60 to 5000 req/hr
# Create at: https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=

# OpenAI API key — enables semantic LLM boost on top of heuristic scoring
# If absent, ranking runs purely on heuristics (still good)
OPENAI_API_KEY=

# ─── Vercel Cron auth (auto-set by Vercel, only needed for local testing) ────
CRON_SECRET=
